# Copier ce fichier en .env et remplir les valeurs
# Ne JAMAIS committer .env dans le repo

# PostgreSQL
POSTGRES_DB=moodit_db
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changez_moi

# JWT — générer avec: openssl rand -base64 64
JWT_SECRET=remplacer_par_un_secret_aleatoire_min_256_bits
JWT_EXPIRATION_MS=604800000

# Pepper (ajouté au mot de passe avant le hash BCrypt) — générer avec: openssl rand -base64 64
APP_SECURITY_PEPPER=une_valeur_longue_et_aleatoire_ici

# App
SPRING_PROFILES_ACTIVE=dev

# Mail (Gmail SMTP) — requis pour les codes de vérification / 2FA
MAIL_USERNAME=votre_email@domaine.com
MAIL_PASSWORD=votre_mot_de_passe(16caract)

# MCP — analyse de cours via un LLM (client compatible OpenAI), servi par mcp-service.
# Par défaut : Ollama LOCAL (aucune donnée ne sort vers un tiers). Le compose Docker lance
# un conteneur `ollama` + tire automatiquement le modèle ; base-url/modèle y sont fixés
# (via host `ollama`). LLM_API_KEY doit être NON-VIDE (le client jette une exception sinon) :
# "ollama" est un simple placeholder. Clé absente ou appel en échec → repli DÉTERMINISTE
# (l'analyse aboutit quand même à partir des vraies stats du cours).
LLM_API_KEY=ollama
# Hors Docker (services lancés à la main) : décommenter pour pointer l'Ollama de l'hôte.
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_MODEL=qwen2.5:7b-instruct
# LLM_TIMEOUT_MS=120000

# Jeton partagé entre mcp-service et core-service pour le pont WebSocket interne
# (/internal/realtime/mcp/**). Doit être IDENTIQUE pour les deux services.
INTERNAL_TOKEN=remplacer_par_un_secret_interne_aleatoire

# Services
FRONTEND_HOST=localhost
FRONTEND_PORT=5173
# Origine autorisée du WebSocket (anti-CSWSH gateway) : l'ORIGINE navigateur du front.
# En prod, mettre l'URL réelle (ex. https://moodit.example.com).
FRONT_ORIGIN=http://localhost:5173

GATEWAY_HOST=localhost
GATEWAY_PORT=8080

CORE_SERVICE_HOST=localhost
CORE_SERVICE_PORT=8081

AUTH_SERVICE_HOST=localhost
AUTH_SERVICE_PORT=8083

MCP_SERVICE_HOST=localhost
MCP_SERVICE_PORT=8082

PERMISSION_SERVICE_HOST=localhost
PERMISSION_SERVICE_PORT=8084

EXEC_SERVICE_HOST=localhost
EXEC_SERVICE_PORT=8085

POSTGRES_HOST=localhost
POSTGRES_PORT=5432

PGADMIN_HOST=localhost
PGADMIN_PORT=9090