# ============================================================================
# .env.docker de PRODUCTION — copier à la RACINE du repo sous le nom .env.docker
#   cp deploy/.env.docker.example .env.docker   (puis remplir les valeurs)
# Ne JAMAIS committer .env.docker (il contient des secrets).
# ============================================================================

# --- PostgreSQL -------------------------------------------------------------
POSTGRES_DB=moodit_db
POSTGRES_USER=moodit
POSTGRES_PASSWORD=CHANGER_mot_de_passe_fort
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# --- Sécurité (générer chaque secret avec : openssl rand -base64 64) ---------
JWT_SECRET=CHANGER_secret_aleatoire_min_256_bits
JWT_EXPIRATION_MS=604800000
APP_SECURITY_PEPPER=CHANGER_valeur_longue_et_aleatoire
# Jeton partagé core <-> mcp pour le pont WebSocket interne. IDENTIQUE des 2 côtés.
INTERNAL_TOKEN=CHANGER_secret_interne_aleatoire

# --- Profil Spring : prod (ddl-auto=validate, pas de données de démo) --------
SPRING_PROFILES_ACTIVE=prod

# --- Mail (codes de vérification / 2FA) — ex. Gmail avec mot de passe d'appli
MAIL_USERNAME=ton_email@domaine.com
MAIL_PASSWORD=mot_de_passe_application_16_caract

# --- LLM MCP = Groq (gratuit, sans carte : https://console.groq.com/keys) ----
# base-url / modèle / timeout sont fixés dans le compose (service mcp-service).
# Ici on ne met que la CLÉ. Si vide ou en échec → repli déterministe (OK pour démo).
LLM_API_KEY=gsk_CHANGER_ta_cle_groq

# --- URLs publiques ---------------------------------------------------------
# FRONT_ORIGIN = origine navigateur RÉELLE (anti-CSWSH du gateway). En HTTPS !
FRONT_ORIGIN=https://moodit.ca
FRONTEND_HOST=moodit.ca
FRONTEND_PORT=5173

# --- Hôtes/ports internes (noms de services docker-compose) -----------------
GATEWAY_HOST=gateway
GATEWAY_PORT=8080
CORE_SERVICE_HOST=core-service
CORE_SERVICE_PORT=8081
AUTH_SERVICE_HOST=auth-service
AUTH_SERVICE_PORT=8083
MCP_SERVICE_HOST=mcp-service
MCP_SERVICE_PORT=8082
PERMISSION_SERVICE_HOST=permission-service
PERMISSION_SERVICE_PORT=8084
EXEC_SERVICE_HOST=execution-service
EXEC_SERVICE_PORT=8085
