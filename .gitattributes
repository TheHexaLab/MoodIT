# Normalisation des fins de ligne : déterministe pour toute l'équipe, quelle que
# soit la config git locale (core.autocrlf). Le dépôt et le worktree restent en LF.
* text=auto eol=lf

# Scripts Windows : doivent rester en CRLF pour s'exécuter correctement.
*.bat text eol=crlf
*.cmd text eol=crlf

# Fichiers binaires : aucune conversion de fins de ligne.
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.svg  text eol=lf
*.jar  binary
*.war  binary
*.woff  binary
*.woff2 binary
*.ttf  binary
*.eot  binary
